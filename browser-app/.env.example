# Supabase (hosted)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role — ONLY used server-side (seed scripts, admin ops)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Voice Gateway (local)
NEXT_PUBLIC_VOICE_GATEWAY_URL=http://localhost:8080

# MCP Server auth — shared secret between voice-gateway and browser-app
# Set the same value in voice-gateway's MCP_AUTH_TOKEN
MCP_AUTH_TOKEN=your-shared-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
