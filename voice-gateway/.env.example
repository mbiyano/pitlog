# ──────────────────────────────────────────────
# voice-gateway environment variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────
# Required. Your OpenAI API key (sk-...).
OPENAI_API_KEY=sk-your-key-here

# OpenAI Realtime model to use.
# Default: gpt-4o-realtime-preview-2024-12-17
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# Voice for the assistant's spoken responses.
# Options: alloy, echo, shimmer, ash, ballad, coral, sage, verse
# Default: shimmer
OPENAI_REALTIME_VOICE=shimmer

# ── Server ────────────────────────────────────
# Port the gateway listens on.
# Default: 8080
PORT=8080

# Node environment. 'development' enables pretty logs and relaxed auth.
# Options: development | production | test
NODE_ENV=development

# Log level.
# Options: trace | debug | info | warn | error | fatal
# Default: info
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed browser origins.
# Default: http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Auth ──────────────────────────────────────
# Optional. If set, the browser must send:
#   Authorization: Bearer <this-token>
# Leave empty to disable auth (local dev only).
GATEWAY_BEARER_TOKEN=

# ── MCP ───────────────────────────────────────
# Set to 'false' to use a real MCP server.
# Default: true (uses in-memory mock data)
USE_MOCK_MCP=true

# Base URL of the real MCP server (required when USE_MOCK_MCP=false).
MCP_SERVER_BASE_URL=http://localhost:4000

# Auth token sent in the Authorization header to the MCP server.
MCP_AUTH_TOKEN=

# ── Sessions ──────────────────────────────────
# How long (ms) an inactive session is kept before auto-cleanup.
# Default: 1800000 (30 minutes)
SESSION_TTL_MS=1800000

# Maximum new sessions allowed per IP per minute.
# Default: 10
RATE_LIMIT_SESSION_PER_MINUTE=10

# Maximum tool calls allowed per response turn (loop protection).
# Default: 5
MAX_TOOL_CALLS_PER_TURN=5

# Maximum events kept in the per-session in-memory journal.
# Default: 200
JOURNAL_MAX_EVENTS=200
